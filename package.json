{
  "name": "AFFINE-tech-tree",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "build:cf": "BUILDING_FOR_CF=1 opennextjs-cloudflare build",
    "check": "tsc --noEmit && eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:sync": "node --env-file=.env --experimental-strip-types src/scripts/sync-topics.ts",
    "db:upload:cf": "(echo 'PRAGMA foreign_keys=OFF;' && sqlite3 db.sqlite \"SELECT 'DROP TABLE IF EXISTS \\\"' || name || '\\\"' || ';' FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%' ORDER BY rowid DESC;\" && sqlite3 db.sqlite .dump | grep -Ev '^(BEGIN TRANSACTION|COMMIT|PRAGMA foreign_keys)') > /tmp/affine-dump.sql && wrangler d1 execute DATABASE_URL --remote --file /tmp/affine-dump.sql",
    "db:download:cf": "wrangler d1 export DATABASE_URL --remote --output /tmp/affine-backup.sql && rm -f db.sqlite && sqlite3 db.sqlite < /tmp/affine-backup.sql",
    "deploy:cf": "BUILDING_FOR_CF=1 opennextjs-cloudflare build && wrangler deploy",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@opennextjs/cloudflare": "^1.16.5",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.10.0",
    "@trpc/next": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.41.0",
    "next": "^15.5.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superjson": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.12",
    "eslint-plugin-drizzle": "^0.2.3",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^2.1.9",
    "wrangler": "^4.65.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.30.0"
}
